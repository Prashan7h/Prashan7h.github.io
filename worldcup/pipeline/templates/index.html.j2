<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-KVBPX8VW');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="FIFA World Cup 2026 fixtures, results, tables and match predictions — Elo ratings and Monte Carlo simulations updated after every game.">
    <link rel="icon" type="image/svg+xml" href="../images/favicon.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="../images/favicon-32.png">
    <title>World Cup 2026 — Fixtures, Table &amp; Predictions</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
{{ style }}
    </style>
</head>
<body>
    <noscript><iframe aria-hidden="true" title="Google Tag Manager" src="https://www.googletagmanager.com/ns.html?id=GTM-KVBPX8VW"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <div class="wrap">
        <div class="masthead">
            <div>
                <h1>World Cup 2026</h1>
                <div class="sub">48 teams · 104 matches · {{ n_finished }} played</div>
            </div>
            <a class="home" href="../index.html">prashanthshankar.com &rarr;</a>
        </div>

        <div class="tabbar" role="tablist">
            <button data-tab="matches" class="active">Matches</button>
            <button data-tab="table">Table</button>
            <button data-tab="predictions">Predictions</button>
            {% if bracket %}<button data-tab="knockout">Knockout</button>{% endif %}
        </div>

        <!-- ============ MATCHES ============ -->
        <div class="panel active" id="panel-matches">
            {% for day in days %}
            <div class="day-head{{ ' today' if day.is_today else '' }}" {% if day.is_today %}id="today"{% endif %}>{{ day.label }}</div>
            {% for m in day.matches %}
            {% if m.has_page %}<a class="fixture" href="matches/{{ m.slug }}.html">{% else %}<div class="fixture">{% endif %}
                <div class="fx-status">
                    {% if m.status == 'finished' %}<span class="chip ft">{{ m.chip or 'FT' }}</span>
                    {% elif m.status == 'live' %}<span class="chip">LIVE</span>
                    {% else %}{{ m.time_short }}{% endif %}
                </div>
                <div class="fx-teams">
                    <div class="fx-row">
                        <span class="t{{ ' win' if m.win1 }}">{{ m.team1 }}</span>
                        {% if m.score %}<span class="s">{{ m.final1 }}</span>{% endif %}
                    </div>
                    <div class="fx-row">
                        <span class="t{{ ' win' if m.win2 }}">{{ m.team2 }}</span>
                        {% if m.score %}<span class="s">{{ m.final2 }}</span>{% endif %}
                    </div>
                </div>
                <div class="fx-meta">{{ m.group or m.round }}<br>{{ m.ground }}{% if m.has_page %}<br><span class="fx-arrow">match report &rarr;</span>{% endif %}</div>
            {% if m.has_page %}</a>{% else %}</div>{% endif %}
            {% endfor %}
            {% endfor %}
        </div>

        <!-- ============ TABLE ============ -->
        <div class="panel" id="panel-table">
            <div class="group-grid">
                {% for gname, table in standings.items() %}
                <div class="card">
                    <div class="card-title">{{ gname }}</div>
                    <table class="t">
                        <thead><tr><th></th><th>Team</th><th class="r">P</th><th class="r">GD</th><th class="r">Pts</th></tr></thead>
                        <tbody>
                        {% for r in table %}
                        <tr><td class="pos">{{ loop.index }}</td><td>{{ r.team }}</td><td class="r">{{ r.p }}</td><td class="r">{{ "%+d" | format(r.gd) if r.gd else 0 }}</td><td class="r pts">{{ r.pts }}</td></tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endfor %}
            </div>
            <p class="foot">Top two of each group advance, plus the eight best third-placed teams.</p>
        </div>

        <!-- ============ PREDICTIONS ============ -->
        <div class="panel" id="panel-predictions">
            <div class="card">
                <div class="card-title">Chance of winning the World Cup</div>
                {% for s in sims[:14] %}
                <div class="odds-row">
                    <span>{{ s.team }}</span>
                    <span class="odds-track"><span style="width: {{ (s.champ / max_champ * 100) | round(1) }}%"></span></span>
                    <span class="odds-pct">{{ "%.1f" | format(s.champ * 100) }}%</span>
                </div>
                {% endfor %}
                <p class="card-note">From {{ "{:,}".format(n_sims) }} Monte Carlo simulations of the remaining tournament, re-run after every match. Goals are Poisson-distributed with rates driven by live Elo ratings (seeded from world ratings, +50 for hosts at home).</p>
            </div>

            <div class="card">
                <div class="card-title">Next matches — model line</div>
                {% for m in upcoming %}
                <div style="padding: 0.45rem 0; {% if not loop.last %}border-bottom: 1px solid #f4f4f4;{% endif %}">
                    <div style="font-size: 0.86rem; font-weight: 700;">{{ m.team1 }} vs {{ m.team2 }} <span style="color:#aaa; font-weight:600; font-size:0.7rem;">· {{ m.date }} · {{ m.group or m.round }}</span></div>
                    <div class="pred-line">{{ m.team1 }} {{ "%.0f" | format(m.pred.p1 * 100) }}% · draw {{ "%.0f" | format(m.pred.pd * 100) }}% · {{ m.team2 }} {{ "%.0f" | format(m.pred.p2 * 100) }}% &nbsp;—&nbsp; most likely score {{ m.pred.score[0] }}–{{ m.pred.score[1] }}</div>
                </div>
                {% endfor %}
            </div>

            {% if upsets %}
            <div class="card">
                <div class="card-title">Biggest upsets so far</div>
                {% for u in upsets[:5] %}
                <div style="font-size: 0.84rem; font-weight: 600; padding: 0.3rem 0;">{{ u.winner }} beat {{ u.loser }} {{ u.score }} <span style="color:#999; font-weight:500;">— model gave them {{ "%.0f" | format(u.win_prob * 100) }}%</span></div>
                {% endfor %}
            </div>
            {% endif %}

            <div class="card">
                <div class="card-title">Model scorecard</div>
                <div class="bigstat">
                    <div class="cell"><div class="n">{{ brier if brier is not none else "—" }}</div><div class="l">Brier score</div></div>
                    <div class="cell"><div class="n">{{ n_scored }}</div><div class="l">Matches scored</div></div>
                    <div class="cell"><div class="n">{{ "{:,}".format(n_sims) }}</div><div class="l">Sims per update</div></div>
                </div>
                <p class="card-note">Brier score measures probability accuracy: 0 is clairvoyant, 0.667 is a three-way shrug. The model is graded on every match it priced before kick-off — no retroactive edits.</p>
            </div>
        </div>

        <!-- ============ KNOCKOUT ============ -->
        {% if bracket %}
        {% macro tie_card(t) %}
        {% if t.has_page %}<a class="bk-card" href="matches/{{ t.slug }}.html">{% else %}<div class="bk-card">{% endif %}
            <div class="bk-side{{ ' win' if t.win1 }}{{ ' ph' if t.s1.placeholder }}">
                <span class="bk-name">{{ t.s1.name }}</span>
                {% if t.score %}<span class="bk-score">{{ t.score[0] }}</span>{% endif %}
            </div>
            <div class="bk-side{{ ' win' if t.win2 }}{{ ' ph' if t.s2.placeholder }}">
                <span class="bk-name">{{ t.s2.name }}</span>
                {% if t.score %}<span class="bk-score">{{ t.score[1] }}</span>{% endif %}
            </div>
            <div class="bk-meta">{{ t.when }}{% if t.note %} · {{ t.note }}{% endif %}{% if t.has_page %} · report &rarr;{% endif %}</div>
        {% if t.has_page %}</a>{% else %}</div>{% endif %}
        {% endmacro %}
        <div class="panel" id="panel-knockout">
            <p class="bk-intro">The road to the final. Teams advance left to right; each tie fills in as results come in. Scroll sideways for the later rounds.</p>
            <div class="bracket-wrap">
                <div class="bracket">
                    {% for col in bracket.columns %}
                    <div class="bk-round{{ ' last' if loop.last }}">
                        <div class="bk-round-head">{{ col.label }}</div>
                        <div class="bk-seeds">
                            {% if col.pairs %}
                                {% for pair in col.pairs %}
                                <div class="bk-pair">
                                    {% for t in pair %}<div class="bk-tie">{{ tie_card(t) }}</div>{% endfor %}
                                </div>
                                {% endfor %}
                            {% else %}
                                {% for t in col.ties %}<div class="bk-tie">{{ tie_card(t) }}</div>{% endfor %}
                            {% endif %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% if bracket.third %}
            <div class="card bk-third">
                <div class="card-title">Third-place play-off</div>
                <div class="bk-tie">{{ tie_card(bracket.third) }}</div>
            </div>
            {% endif %}
        </div>
        {% endif %}

        <p class="foot">Built as a fully automated pipeline: results and shot-level data are pulled from public sources, an Elo system is replayed over every result, and the tournament is re-simulated {{ "{:,}".format(n_sims) }} times — every six hours, via GitHub Actions, with no human in the loop. Last build {{ build_time }}.</p>
    </div>

    <script>
    (function () {
        var buttons = document.querySelectorAll('.tabbar button');
        function show(name) {
            buttons.forEach(function (b) { b.classList.toggle('active', b.dataset.tab === name); });
            document.querySelectorAll('.panel').forEach(function (p) {
                p.classList.toggle('active', p.id === 'panel-' + name);
            });
            if (history.replaceState) history.replaceState(null, '', '#' + name);
        }
        buttons.forEach(function (b) {
            b.addEventListener('click', function () { show(b.dataset.tab); });
        });
        var hash = location.hash.replace('#', '');
        if (hash === 'table' || hash === 'predictions' || hash === 'knockout') show(hash);
        var today = document.getElementById('today');
        if (today && (!hash || hash === 'matches')) {
            setTimeout(function () {
                today.scrollIntoView({ block: 'start' });
                window.scrollBy(0, -56); /* clear the sticky tab bar */
            }, 0);
        }
    })();
    </script>
</body>
</html>
